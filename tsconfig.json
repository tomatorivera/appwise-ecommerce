{
  "compilerOptions": {
    "target": "ES2020",

    "lib": ["DOM", "DOM.Iterable", "ES2020"],

    "jsx": "react-jsx",

    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["vite/client"],

    "strict": true,
    "noUnusedLocals": true,

    "skipLibCheck": true,

    "noEmit": true
  },

  "include": ["src", "commitlint.config.js"]
}
